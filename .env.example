# Local database
# Defaults to data/panely.sqlite inside the project.
# PANELY_DB_PATH=/Users/you/.panely/panely.sqlite

# Stripe (optional billing experiments; not required for local advisory sessions)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Local model routing
# Panely uses local subscription CLIs directly: claude, codex, and gemini.
# Run `claude auth`, `codex login`, and `gemini` setup locally as needed.
